# Copy to .streamlit/secrets.toml and fill in real values. NEVER commit secrets.toml.
#
# This file is for LOCAL dev. In a hosted container you can instead supply everything
# via env vars (they take precedence over this file) — see README "Container image":
#   [snowflake] -> SNOWFLAKE_ACCOUNT/_USER/_ROLE/_WAREHOUSE/_DATABASE/_SCHEMA
#   private_key_file -> SNOWFLAKE_PRIVATE_KEY_PATH (default /run/secrets/rsa_key.p8)
#   private_key_passphrase -> SNOWFLAKE_PRIVATE_KEY_PASSPHRASE
#   [cookie] key -> COOKIE_KEY (name/expiry_days -> COOKIE_NAME/COOKIE_EXPIRY_DAYS)

# --- Snowflake (key-pair / JWT auth) ---
[snowflake]
account          = "your_account"
user             = "SVC_REPORTS"
private_key_file = "svc_reports_key_1.pem"   # path to the PEM (mounted secret in prod)
# private_key_passphrase = "…"               # only if the key is encrypted
role             = "ACCOUNTADMIN"           # local dev; prod: use a least-privilege role (see docs/ARCHITECTURE.md)
warehouse        = "DBT_DEV_XS"
database         = "SALES_ANALYTICS"
schema           = "PUBLIC"

# --- Login session cookie (streamlit-authenticator) ---
# User credentials themselves live in the Snowflake DASHBOARD_USERS table
# (bcrypt hashes) — NOT here. This key only signs the session cookie.
[cookie]
name        = "urvenue_dashboards"
key         = "REPLACE_WITH_LONG_RANDOM_STRING"   # python -c "import secrets;print(secrets.token_hex(32))"
expiry_days = 1

# --- Access ---
# dev_bypass is LOCAL ONLY — skips the login form and serves dev_tenant.
# Remove both for any hosted/production deployment.
[access]
# dev_bypass = true
# dev_tenant = "abbaye"
